{\n  "estrategias": [\n    {\n      "pilar": "PILAR 1: VOTORANTIM CONECTA E REALIZA",\n      "taticas": [\n        {\n          "numero": 1,\n          "nome": "App-Solução em 1 Minuto",\n          "descricao": "Crie uma série de vídeos verticais de 60 segundos para TikTok, Reels e Shorts. Cada vídeo mostra um cidadão encenando um problema cotidiano (ex: 'Fila interminável no posto de saúde') e, com um clique no 'App Votorantim', a solução aparece ('Consulta agendada em 24h').",\n          "mensagem": "Gestão eficiente que resolve.",\n          "viral": "Formato rápido, problema universal, solução visual.",\n          "opiniao": "Posiciona o candidato como o solucionador tecnológico.",\n          "mobilizacao": "Inclua call-to-action (CTA) 'Baixe o protótipo da ideia no link da bio e vote para ela virar realidade'."\n        },\n        {\n          "numero": 2,\n          "nome": "Plebiscito Digital do Parque",\n          "descricao": "Lance uma plataforma simples (microsite ou dentro do app da campanha) com três opções de melhorias para um espaço público subutilizado. Use anúncios segmentados geograficamente para impulsionar a votação.",\n          "mensagem": "Sua voz define a obra.",\n          "viral": "Crie gráficos comparativos e time-lapses virtuais do 'parque vencedor'.",\n          "opiniao": "Gera manchetes locais sobre 'democracia digital inédita'.",\n          "mobilizacao": "Mobilize grupos de bairro e escolas próximas para votarem, transformando a consulta em uma ação comunitária."\n        },\n        {\n          "numero": 3,\n          "nome": "Hashtag #MinhaVoto2030 - O Desafio da Ideia",\n          "descricao": "Lance um desafio nas redes: 'Poste um vídeo de 15 segundos com sua ideia para Votorantim usando #MinhaVoto2030. As 10 melhores serão debatidas em live com o candidato.'",\n          "mensagem": "A cidade é construção coletiva.",\n          "viral": "Incentiva UGC (Conteúdo Gerado pelo Usuário) e cria uma biblioteca de ideias autênticas.",\n          "opiniao": "Mostra a campanha como um canal aberto e receptivo.",\n          "mobilizacao": "Premie os vencedores com um 'Jantar com o Futuro Prefeito', criando embaixadores hiper-engajados."\n        }\n      ]\n    },\n    {\n      "pilar": "PILAR 2: FORTALEZA DOS CAMPEÕES",\n      "taticas": [\n        {\n          "numero": 4,\n          "nome": "Embaixadores da Mudança - Série de Depoimentos Crus",\n          "descricao": "Produza uma série de vídeos depoimento, filmados com celular, com moradores, professores e líderes dos *Locais-Campeões* (ex: EE. Prof. Armando Rizzo). Pergunta: 'Por que aqui a campanha decolou?'.",\n          "mensagem": "A força vem das pessoas.",\n          "viral": "Conteúdo orgânico e autêntico que gera identificação.",\n          "opiniao": "Prova social irrefutável e emocional.",\n          "mobilizacao": "Exiba esses vídeos em telões nos *Locais de Potencial* para inspirar e mostrar o 'caminho do sucesso'."\n        },\n        {\n          "numero": 5,\n          "nome": "Círculo dos Campeões - Intercâmbio de Mobilizadores",\n          "descricao": "Formalize um programa onde os coordenadores dos 3 principais *Locais-Campeões* realizam um 'sábado de treinamento' com os voluntários dos 3 principais *Locais de Potencial'.",\n          "mensagem": "Juntos, somos mais fortes.",\n          "viral": "Documente o treinamento em stories com antes/depois das equipes.",\n          "opiniao": "Posiciona a campanha como uma rede colaborativa e inteligente.",\n          "mobilizacao": "Transfere *know-how* tático comprovado, potencializando a captação nos locais com maior margem de crescimento."\n        },\n        {\n          "numero": 6,\n          "nome": "Meta Estourada: A Gincana dos 718%",\n          "descricao": "Crie uma narrativa interna e externa em torno do número 718.4% (superação da meta). Para voluntários: lance uma gincana com metas setoriais (ex: 'Levar a Zona X a bater 1000%').",\n          "mensagem": "Somos uma máquina de vencer.",\n          "viral": "Gráficos animados e contagens regressivas nas redes da campanha.",\n          "opiniao": "Usar esse dado em debates e artigos como símbolo de competência organizacional inigualável.",\n          "mobilizacao": "A gincana gera competição saudável e propósito entre as equipes de base."\n        },\n        {\n          "numero": 7,\n          "nome": "Ação-Teste no CMEI Romana",\n          "descricao": "Direcione um *kit* completo de mobilização (material gráfico, roteiro de porta-a-porta, estrutura para um pequeno evento) especificamente para o CMEI Romana Frederico Bauch (local de alto potencial). Monitore os resultados por uma semana.",\n          "mensagem": "Sua comunidade é nossa prioridade agora.",\n          "viral": "Faça um documentário de 5 minutos 'A Transformação de uma Semana' mostrando a ação.",\n          "opiniao": "Demonstra foco e capacidade de execução direcionada.",\n          "mobilizacao": "Testa e refina táticas de campo que depois podem ser escaladas para outros locais de potencial."\n        }\n      ]\n    },\n    {\n      "pilar": "PILAR 3: EIXOS QUE VIRAM MEMES",\n      "taticas": [\n        {\n          "numero": 8,\n          "nome": "Família de Memes dos 5 Eixos",\n          "descricao": "Crie um personagem ou formato visual distinto para cada eixo. Ex: Para **'Acolhedora'**, um meme com um abraço enorme e o texto 'Quando a prefeitura te ouve de verdade'. Para **'Sustentável'**, um meme do planeta Terra sorrindo com a logo da campanha.",\n          "mensagem": "Traduz complexidade em emoção pura.",\n          "viral": "Facilmente compartilhável, cria identidade visual para cada pilar.",\n          "opiniao": "Faz a agenda programática entrar no imaginário popular de forma descontraída.",\n          "mobilizacao": "Incentive os apoiadores a criarem seus próprios memes com uma *hashtag* específica (#MemesDaVoto)."\n        },\n        {\n          "numero": 9,\n          "nome": "Filtro do Futuro no Instagram",\n          "descricao": "Desenvolva um filtro de realidade aumentada para Instagram. Ao ativá-lo, a tela mostra a rua do usuário 'transformada': mais verde, com ciclovia, wi-fi público (simbolizando os eixos).",\n          "mensagem": "Veja o futuro da sua cidade agora.",\n          "viral": "Filtros são ferramentas orgânicas poderosíssimas.",\n          "opiniao": "Associa a campanha à inovação e a uma visão tangível de futuro.",\n          "mobilizacao": "Promova um concurso: 'Use o filtro, marque a campanha e concorra a um prêmio'. Aumenta o alcance orgânico massivamente."\n        },\n        {\n          "numero": 10,\n          "nome": "Podcast Temático: O Eixo em Ação",\n          "descricao": "Produza uma minissérie de 5 episódios de podcast, um para cada eixo. Convide um especialista (ex: um médico para 'Saudável') e um cidadão para debaterem as propostas.",\n          "mensagem": "Profundidade e seriedade por trás dos slogans.",\n          "viral": "Clipes de 30 segundos dos melhores momentos viram cards para redes sociais.",\n          "opiniao": "Conquista a opinião pública qualificada e a mídia tradicional.",\n          "mobilizacao": "Distribua os episódios para grupos específicos (conselhos de saúde, associações de bairro, sindicatos de professores)."\n        },\n        {\n          "numero": 11,\n          "nome": "Tradução de Jargão: O Dicionário Votorantim",\n          "descricao": "Crie uma série de *carrosséis* no Instagram e posts no LinkedIn. De um lado, o 'Juridiquês' ('Fortalecimento das dimensões político-institucionais'). Do outro, a 'Tradução Votorantim' ('Vamos dar poder real aos conselhos da cidade').",\n          "mensagem": "Clareza é respeito.",\n          "viral": "Formato educativo e de fácil digestão que desmistifica a política.",\n          "opiniao": "Posiciona o candidato como comunicador eficaz e transparente.",\n          "mobilizacao": "Esse conteúdo serve como treinamento essencial para todos os voluntários, uniformizando a comunicação de rua."\n        },\n        {\n          "numero": 12,\n          "nome": "Nicho Engajado: Os Guardiões da Sustentabilidade",\n          "descricao": "Identifique influenciadores locais de meio ambiente, ciclistas e líderes comunitários verdes. Ofereça a eles um 'tour virtual' pelas propostas do eixo Sustentável e crie um grupo de WhatsApp exclusivo.",\n          "mensagem": "Sua causa tem um lugar na nossa gestão.",\n          "viral": "Esses influenciadores geram conteúdo autêntico para seus nichos.",\n          "opiniao": "Captura a opinião de um segmento crítico e mobilizado.",\n          "mobilizacao": "Transforma esse grupo em uma força-tarefa para ações específicas, como mutirões de limpeza."\n        },\n        {\n          "numero": 13,\n          "nome": "Contraste Visual: O Antes (Genérico) vs. O Depois (Nossa Solução)",\n          "descricao": "Para cada eixo, produza uma peça gráfica ou vídeo curto. Na metade esquerda, uma imagem genérica de problema com texto vago ('Mais saúde'). Na direita, uma imagem da proposta concreta da campanha com texto específico ('App + 10 UPAs 24h').",\n          "mensagem": "Chega de promessas vazias. Aqui está o plano.",\n          "viral": "O formato de comparação é altamente compartilhável e compreensível.",\n          "opiniao": "Molda a percepção de que os rivais são vagos, enquanto esta campanha é concreta.",\n          "mobilizacao": "Essa peça é a arma definitiva para o porta-a-porta e para debates, dando argumento claro a cada mobilizador."\n        }\n      ]\n    }\n  ]\n}
